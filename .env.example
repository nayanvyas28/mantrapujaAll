# --- SHARED SUPABASE CONFIG ---
# Used by: website, mobile-app, admin-panel, backend
NEXT_PUBLIC_SUPABASE_URL=https://s1.mantrapuja.com
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# --- ASTROLOGY API CONFIG ---
# Used by: website, backend (for mobile app)
PROKERALA_CLIENT_ID=your_client_id_here
PROKERALA_CLIENT_SECRET=your_client_secret_here

# --- SECURITY CONFIG ---
# Used by: admin-panel, backend
ENCRYPTION_STRING_KEY=your_encryption_key_here

# --- APP URLS ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ADMIN_URL=http://localhost:3001
NEXT_PUBLIC_API_URL=http://localhost:4000

# --- N8N WEBHOOKS ---
N8N_WEBHOOK_SECRET=your_n8n_secret_here
